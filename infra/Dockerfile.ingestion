FROM python:3.11-slim
WORKDIR /app
COPY ingestion/requirements.txt /app/ingestion/requirements.txt
RUN pip install --no-cache-dir -r /app/ingestion/requirements.txt
# ca-certificates: DuckDB's Azure client verifies TLS against the system CA bundle, which the
# slim image lacks (delta-rs bundles its own via rustls, so it isn't affected). Placed AFTER pip
# so the pip layer stays cached on rebuild.
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*
# Code is bind-mounted at /app/ingestion; run as: python -m ingestion.reference_sync
